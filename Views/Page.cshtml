@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IPublishedContent>
@using Umbraco.Cms.Core.Models.Blocks
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    var pageTitle = Model.Name;
    var pageSummary = Model.Value<string>("summaryContent");
    var blocks = Model.Value<BlockListModel>("blocks");

    ViewData["Title"] = pageTitle;
}

<div class="site-container">
    <div class="page-stack">
        <section class="page-intro">
            <h1 class="page-title">@pageTitle</h1>
            @if (!string.IsNullOrWhiteSpace(pageSummary))
            {
                <p class="page-meta">@pageSummary</p>
            }
        </section>

        @if (blocks?.Any() == true)
        {
            @await Html.PartialAsync("~/Views/Partials/blocklist/default.cshtml", blocks)
        }
        else
        {
            <section class="content-section content-panel">
                <p>No content blocks are configured for this page yet.</p>
            </section>
        }
    </div>
</div>