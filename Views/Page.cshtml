@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IPublishedContent>
@using Umbraco.Cms.Core.Models.Blocks
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var blocks = Model?.Value<IEnumerable<BlockListItem>>("blocks") ?? Enumerable.Empty<BlockListItem>();
}

<div class="mx-auto grid w-full max-w-[var(--layout-width-container)] gap-8 px-gutter">

    @if (blocks?.Any() == true)
    {
        @await Html.PartialAsync("~/Views/Partials/blocklist/default.cshtml", blocks)
    }
    else
    {
        <section class="grid gap-4 rounded-card border border-border-subtle bg-panel p-6 shadow-card">
            <p>No content blocks are configured for this page yet.</p>
        </section>
    }
</div>
