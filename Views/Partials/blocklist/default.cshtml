@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListModel>
@{
    if (Model?.Any() != true) { return; }
}
<div class="block-flow">
    @foreach (var block in Model)
    {
        if (block?.ContentKey == null) { continue; }
        var data = block.Content;
        var partialViewName = "~/Views/Partials/Blocks/" + data.ContentType.Alias + ".cshtml";
        try
        {
            @await Html.PartialAsync(partialViewName, block)
        }
        catch (InvalidOperationException)
        {
            <section class="content-section content-panel">
                <p>
                    Missing block partial for <strong>@data.ContentType.Alias</strong>.
                </p>
            </section>
        }
    }
</div>
