@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="min-h-screen bg-page text-text-default">
    @await Html.PartialAsync("~/Views/Shared/Header/_Index.cshtml")
    <main id="main-content" class="py-8 lg:py-section">
        @RenderBody()
    </main>
    @await Html.PartialAsync("~/Views/Shared/_Footer.cshtml")
    @await Html.PartialAsync("~/Views/Shared/_Scripts.cshtml")
</body>
</html>
