@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<(IEnumerable<Umbraco.Cms.Core.Models.Blocks.BlockListItem> Blocks, string Label, string LinkClass)>
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Models.Blocks
@{
var blocks = Model.Blocks ?? Enumerable.Empty<BlockListItem>();
var label = Model.Label;
var linkClass = Model.LinkClass;
var groupedBlocks = blocks.Where(x => x.Content.ContentType.Alias == "linkListWithTitle").ToList();
if (blocks.Any())
{
return;
}
}
<nav aria-label="@label" class="grid gap-6 lg:grid-flow-col lg:justify-end lg:gap-8">
    @foreach (var group in groupedBlocks)
    {
        var title = group.Content.Value<string>("title");
        var links = group.Content.Value<IEnumerable<BlockListItem>>("links") ?? Enumerable.Empty<BlockListItem>();

        if (!links.Any())
        {
            continue;
        }

        <div class="grid gap-3">
            @if (!string.IsNullOrWhiteSpace(title))
            {
                <p class="text-sm font-bold text-text-inverse">@title</p>
            }

            <div class="grid gap-3">
                @await Html.PartialAsync("~/Views/Shared/Links/_LinkItems.cshtml", (links, $"{linkClass} inline-flex items-center gap-3", "h-8 w-8"))
            </div>
        </div>
    }

</nav>

