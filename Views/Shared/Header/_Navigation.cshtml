@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<IEnumerable<Umbraco.Cms.Core.Models.Blocks.BlockListItem>>
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Models.Blocks
@{
    var blocks = Model ?? Enumerable.Empty<BlockListItem>();
}

@if (blocks.Any())
{
    <nav id="site-main-navigation" aria-label="Main navigation" class="hidden grid-cols-1 border-t border-border-subtle pt-4 lg:grid lg:grid-flow-col lg:justify-end lg:gap-6 lg:border-t-0 lg:pt-0">
        @foreach (var block in blocks)
        {
            var content = block.Content;
            var link = content.Value<Link>("link")
                ?? content.Value<IEnumerable<Link>>("link")?.FirstOrDefault();

            if (link is null)
            {
                continue;
            }

            var linkUrl = link.Url?.ToString() ?? "#";
            var linkTarget = link.Target?.ToString();
            var linkName = string.IsNullOrWhiteSpace(link.Name) ? linkUrl : link.Name;
            <a class="block w-full border-b border-border-subtle py-3 text-text-strong no-underline last:border-b-0 lg:w-auto lg:border-b-0 lg:py-0" href="@linkUrl" target="@linkTarget">@linkName</a>
        }
    </nav>
}
