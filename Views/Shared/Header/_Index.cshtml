@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Models.Blocks
@{
    var siteSettings = Umbraco.ContentAtRoot().FirstOrDefault(x => x.ContentType.Alias == "siteSettings");
    var siteName = siteSettings?.Value<string>("siteName") ?? "Site";
    var headerBlock = siteSettings?.Value<BlockListItem>("header");
}

@if (headerBlock is not null)
{
    @await Html.PartialAsync("~/Views/Shared/Header/_Header.cshtml", (siteName, headerBlock))
}
