      <Mandatory>false</Mandatory>
      <Validation></Validation>
      <Description><![CDATA[Sets the maximum width for standard page sections such as headers, footers, and general content blocks. Use a CSS length like <code>80rem</code>, <code>1200px</code>, or <code>min(100% - 2rem, 80rem)</code>.]]></Description>
