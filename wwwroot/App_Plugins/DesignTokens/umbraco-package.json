{
  "$schema": "../../umbraco-package-schema.json",
  "name": "My.ThemeSettings",
  "version": "1.0.1",
  "extensions": [
    {
      "type": "propertyEditorUi",
      "alias": "My.PropertyEditorUi.Contentment.ColorSwatches",
      "name": "Contentment Color Swatches",
      "element": "/App_Plugins/DesignTokens/color-swatches.element.js",
      "elementName": "my-contentment-color-swatches",
      "meta": {
        "label": "Contentment Color Swatches",
        "icon": "icon-colorpicker",
        "group": "common",
        "propertyEditorSchemaAlias": "Umbraco.Plain.String"
      }
    },
    {
      "type": "propertyEditorUi",
      "alias": "My.PropertyEditorUi.ResponsiveSpacingValue",
      "name": "Responsive Spacing Value",
      "element": "/App_Plugins/DesignTokens/responsive-spacing-value.element.js",
      "elementName": "my-responsive-spacing-value",
      "meta": {
        "label": "Responsive Spacing Value",
        "icon": "icon-ruler",
        "group": "common",
        "propertyEditorSchemaAlias": "Umbraco.Plain.String"
      }
    },
    {
      "type": "propertyEditorUi",
      "alias": "My.PropertyEditorUi.FontFamilyValue",
      "name": "Font Family Value",
      "element": "/App_Plugins/DesignTokens/font-family-value.element.js",
      "elementName": "my-font-family-value",
      "meta": {
        "label": "Font Family Value",
        "icon": "icon-text-color",
        "group": "common",
        "propertyEditorSchemaAlias": "Umbraco.Plain.String"
      }
    },
    {
      "type": "blockEditorCustomView",
      "alias": "My.BlockEditorCustomView.BuiltInBaseColor",
      "name": "Built-in Base Color View",
      "element": "/App_Plugins/DesignTokens/primitive-color-block-view.element.js",
      "elementName": "my-base-color-block-view",
      "forContentTypeAlias": "colorToken",
      "forBlockEditor": "block-list"
    },
    {
      "type": "blockEditorCustomView",
      "alias": "My.BlockEditorCustomView.CustomBaseColor",
      "name": "Custom Base Color View",
      "element": "/App_Plugins/DesignTokens/primitive-color-block-view.element.js",
      "elementName": "my-base-color-block-view",
      "forContentTypeAlias": "customColorToken",
      "forBlockEditor": "block-list"
    },
    {
      "type": "blockEditorCustomView",
      "alias": "My.BlockEditorCustomView.SpacingToken",
      "name": "Spacing View",
      "element": "/App_Plugins/DesignTokens/spacing-token-block-view.element.js",
      "elementName": "my-spacing-token-block-view",
      "forContentTypeAlias": "spacing",
      "forBlockEditor": "block-list"
    }
  ]
}
