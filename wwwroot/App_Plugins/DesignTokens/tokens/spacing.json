{
  "space": {
    "none": {
      "$type": "dimension",
      "$extensions": {
        "site": {
          "alias": "space-none",
          "label": "None"
        }
      },
      "$value": {
        "mobile": "0px",
        "tablet": "0px",
        "laptop": "0px",
        "desktop": "0px"
      }
    },
    "xs": {
      "$type": "dimension",
      "$extensions": {
        "site": {
          "alias": "space-xs",
          "label": "XSmall"
        }
      },
      "$value": {
        "mobile": "4px",
        "tablet": "6px",
        "laptop": "8px",
        "desktop": "8px"
      }
    },
    "sm": {
      "$type": "dimension",
      "$extensions": {
        "site": {
          "alias": "space-sm",
          "label": "Small"
        }
      },
      "$value": {
        "mobile": "8px",
        "tablet": "10px",
        "laptop": "12px",
        "desktop": "12px"
      }
    },
    "md": {
      "$type": "dimension",
      "$extensions": {
        "site": {
          "alias": "space-md",
          "label": "Medium"
        }
      },
      "$value": {
        "mobile": "12px",
        "tablet": "16px",
        "laptop": "20px",
        "desktop": "24px"
      }
    },
    "lg": {
      "$type": "dimension",
      "$extensions": {
        "site": {
          "alias": "space-lg",
          "label": "Large"
        }
      },
      "$value": {
        "mobile": "16px",
        "tablet": "24px",
        "laptop": "28px",
        "desktop": "32px"
      }
    },
    "xl": {
      "$type": "dimension",
      "$extensions": {
        "site": {
          "alias": "space-xl",
          "label": "XLarge"
        }
      },
      "$value": {
        "mobile": "24px",
        "tablet": "32px",
        "laptop": "40px",
        "desktop": "48px"
      }
    }
  }
}
